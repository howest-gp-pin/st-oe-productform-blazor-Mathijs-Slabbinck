@inherits LayoutComponentBase

<a href="#main-content" class="skip-link">Skip to main content</a>

<div class="page">
    <nav class="sidebar" aria-label="Main navigation">
        <NavMenu />
    </nav>

    <main id="main-content">
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank" rel="noopener noreferrer">
                About <span class="visually-hidden">(opens in new tab)</span>
            </a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload" aria-label="Reload page">Reload</a>
    <button class="dismiss" aria-label="Dismiss error">&#x2715;</button>
</div>
